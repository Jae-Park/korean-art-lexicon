{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korean-art-lexicon.org/schema/publication.schema.json",
  "title": "Publication",
  "description": "A publication entity in the Korean Art Lexicon — exhibition catalogues, monographs, periodicals, anthologies",
  "type": "object",
  "required": [
    "id",
    "title",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^publication\\.[a-z0-9-]+$",
      "description": "Unique identifier in format: publication.{slug}"
    },
    "title": {
      "type": "object",
      "required": ["ko"],
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "string",
          "minLength": 1,
          "description": "Korean title"
        },
        "en": {
          "type": "string",
          "minLength": 1,
          "description": "English title"
        },
        "note": {
          "type": "string",
          "description": "Note about title (e.g. 공식 한국어 제목 미발견)"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["form", "lang"],
            "additionalProperties": false,
            "properties": {
              "form": {
                "type": "string",
                "minLength": 1,
                "description": "The title variant string"
              },
              "lang": {
                "type": "string",
                "description": "ISO 639-1 language code"
              },
              "script": {
                "type": "string",
                "enum": ["Hang", "Hani", "Kore", "Latn", "Jpan", "Hans", "Hant"],
                "description": "ISO 15924 script code"
              },
              "type": {
                "type": "string",
                "enum": ["preferred", "alternate", "abbreviation", "former", "transliteration"],
                "description": "Variant type"
              },
              "source": {
                "type": "string",
                "description": "Institution or publication where this variant is used"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          },
          "description": "Title variants with language, script, and provenance"
        }
      }
    },
    "type": {
      "type": "object",
      "required": ["aat"],
      "additionalProperties": false,
      "properties": {
        "aat": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Getty AAT Subject ID (e.g. 300026096 = exhibition catalogs)"
        }
      },
      "description": "Publication type as Getty AAT ID"
    },
    "publisher": {
      "type": "string",
      "description": "Publisher name"
    },
    "year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100,
      "description": "Year of publication"
    },
    "isbn": {
      "type": "string",
      "description": "ISBN identifier"
    },
    "issn": {
      "type": "string",
      "description": "ISSN identifier (for periodicals)"
    },
    "language": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "ISO 639-1 language code"
      },
      "description": "Languages of the publication"
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(person|org|term|exhibition|publication)\\.[a-z0-9-]+$"
      },
      "description": "Related entities (e.g. exhibition catalogue → exhibition, author → person)"
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wikidata": {
          "type": "string",
          "pattern": "^Q[0-9]+$",
          "description": "Wikidata Q-item ID"
        },
        "aaa": {
          "type": "string",
          "description": "Asia Art Archive library record ID"
        },
        "worldcat": {
          "type": "string",
          "description": "WorldCat OCLC number"
        }
      },
      "description": "Links to external databases"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": ["url"],
            "additionalProperties": false,
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              },
              "name_used": {
                "type": "string",
                "description": "Title form used in this source"
              },
              "note": {
                "type": "string"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          }
        ]
      },
      "description": "Verifiable sources"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "reviewed",
        "firsthand",
        "stable",
        "rejected"
      ],
      "default": "draft"
    },
    "notes": {
      "type": "string"
    }
  }
}
