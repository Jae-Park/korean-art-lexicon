{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korean-art-lexicon.org/schema/person.schema.json",
  "title": "Person",
  "description": "A person entity in the Korean Art Lexicon — naming authority for Korean contemporary art",
  "type": "object",
  "required": [
    "id",
    "name",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^person\\.[a-z0-9-]+$",
      "description": "Unique identifier in format: person.{family-given-lowercase}"
    },
    "name": {
      "type": "object",
      "required": [
        "ko",
        "latn"
      ],
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "object",
          "required": [
            "full",
            "family",
            "given"
          ],
          "additionalProperties": false,
          "properties": {
            "full": {
              "type": "string",
              "minLength": 1,
              "description": "Full Korean name (한글)"
            },
            "family": {
              "type": "string",
              "minLength": 1,
              "description": "Family name (성)"
            },
            "given": {
              "type": "string",
              "minLength": 1,
              "description": "Given name (이름)"
            },
            "hanja": {
              "type": "string",
              "description": "Name in Chinese characters (한자) — optional"
            }
          }
        },
        "latn": {
          "type": "object",
          "required": [
            "preferred",
            "family",
            "given"
          ],
          "additionalProperties": false,
          "properties": {
            "preferred": {
              "type": "string",
              "minLength": 1,
              "description": "Preferred romanized full name (as officially used by the person)"
            },
            "family": {
              "type": "string",
              "minLength": 1,
              "description": "Romanized family name"
            },
            "given": {
              "type": "string",
              "minLength": 1,
              "description": "Romanized given name"
            }
          }
        }
      }
    },
    "birth_year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100,
      "description": "Year of birth — must be verifiable from at least one source"
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ulan": {
          "type": "string",
          "description": "Getty ULAN Subject ID"
        },
        "wikidata": {
          "type": "string",
          "pattern": "^Q[0-9]+$",
          "description": "Wikidata Q-item ID"
        },
        "viaf": {
          "type": "string",
          "description": "VIAF cluster ID"
        },
        "isni": {
          "type": "string",
          "description": "ISNI identifier"
        }
      },
      "description": "Links to global authority files (optional, added when verified)"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "url",
          "name_used"
        ],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1,
            "description": "Source URL"
          },
          "name_used": {
            "type": "string",
            "minLength": 1,
            "description": "The romanized name form used in this source"
          },
          "note": {
            "type": "string",
            "description": "Additional context (optional)"
          }
        }
      },
      "description": "Verifiable sources with the name form used in each — the core data of this lexicon"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "reviewed",
        "firsthand",
        "stable",
        "rejected"
      ],
      "default": "draft",
      "description": "Entry status"
    },
    "notes": {
      "type": "string",
      "description": "Internal notes (optional)"
    }
  }
}