{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korean-art-lexicon.org/schema/person.schema.json",
  "title": "Person",
  "description": "A person entity in the Korean Art Lexicon — naming authority for Korean contemporary art",
  "type": "object",
  "required": [
    "id",
    "name",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^person\\.[a-z0-9-]+$",
      "description": "Unique identifier in format: person.{family-given-lowercase}"
    },
    "name": {
      "type": "object",
      "required": [
        "ko",
        "latn"
      ],
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "object",
          "required": [
            "full"
          ],
          "additionalProperties": false,
          "properties": {
            "full": {
              "type": "string",
              "minLength": 1,
              "description": "Full Korean name (한글) or Korean transcription of foreign name"
            },
            "family": {
              "type": "string",
              "minLength": 1,
              "description": "Family name (성) — optional for foreign names"
            },
            "given": {
              "type": "string",
              "minLength": 1,
              "description": "Given name (이름) — optional for foreign names"
            },
            "hanja": {
              "type": "string",
              "description": "Name in Chinese characters (한자) — optional"
            }
          }
        },
        "latn": {
          "type": "object",
          "required": [
            "preferred"
          ],
          "additionalProperties": false,
          "properties": {
            "preferred": {
              "type": "string",
              "minLength": 1,
              "description": "Preferred romanized full name (as officially used by the person)"
            },
            "family": {
              "type": "string",
              "minLength": 1,
              "description": "Romanized family name"
            },
            "given": {
              "type": "string",
              "minLength": 1,
              "description": "Romanized given name"
            }
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["form", "lang"],
            "additionalProperties": false,
            "properties": {
              "form": {
                "type": "string",
                "minLength": 1,
                "description": "The name variant string"
              },
              "lang": {
                "type": "string",
                "description": "ISO 639-1 language code (ko, en, ja, zh, etc.)"
              },
              "script": {
                "type": "string",
                "enum": ["Hang", "Hani", "Kore", "Latn", "Jpan", "Hans", "Hant"],
                "description": "ISO 15924 script code"
              },
              "type": {
                "type": "string",
                "enum": ["preferred", "alternate", "pseudonym", "birth_name", "art_name", "abbreviation", "former", "transliteration"],
                "description": "Variant type — aligned with ULAN Term_Type"
              },
              "romanization": {
                "type": "string",
                "enum": ["revised", "mcr", "yale", "artist", "conventional"],
                "description": "Romanization system (person-specific, only when script=Latn)"
              },
              "display_order": {
                "type": "string",
                "enum": ["given-family", "family-given"],
                "description": "Name display order (person-specific)"
              },
              "source": {
                "type": "string",
                "description": "Institution or publication where this variant is used"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          },
          "description": "Name variants with language, script, and provenance — core value of this lexicon"
        }
      }
    },
    "nationality": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 country code (e.g. KR, GB, US)"
    },
    "birth_year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100,
      "description": "Year of birth — must be verifiable from at least one source"
    },
    "death_year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100,
      "description": "Year of death — must be verifiable from at least one source"
    },
    "role": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["aat"],
        "additionalProperties": false,
        "properties": {
          "aat": {
            "type": "string",
            "pattern": "^[0-9]+$",
            "description": "Getty AAT Subject ID for the role/occupation"
          }
        }
      },
      "description": "Roles/occupations as Getty AAT IDs (e.g. 300025103 = artists)"
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ulan": {
          "type": "string",
          "description": "Getty ULAN Subject ID"
        },
        "wikidata": {
          "type": "string",
          "pattern": "^Q[0-9]+$",
          "description": "Wikidata Q-item ID"
        },
        "viaf": {
          "type": "string",
          "description": "VIAF cluster ID"
        },
        "isni": {
          "type": "string",
          "description": "ISNI identifier"
        },
        "aaa": {
          "type": "string",
          "description": "Asia Art Archive actor ID (e.g. actors:197)"
        }
      },
      "description": "Links to global authority files (optional, added when verified)"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "url",
          "name_used"
        ],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1,
            "description": "Source URL"
          },
          "name_used": {
            "type": "string",
            "minLength": 1,
            "description": "The name form used in this source"
          },
          "note": {
            "type": "string",
            "description": "Additional context (optional)"
          },
          "accessed": {
            "type": "string",
            "format": "date",
            "description": "Date the source was last accessed (YYYY-MM-DD)"
          }
        }
      },
      "description": "Verifiable sources with the name form used in each — the core data of this lexicon"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "reviewed",
        "firsthand",
        "stable",
        "rejected"
      ],
      "default": "draft",
      "description": "Entry status"
    },
    "notes": {
      "type": "string",
      "description": "Internal notes (optional)"
    }
  }
}
