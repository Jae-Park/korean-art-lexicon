{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korean-art-lexicon.org/schema/term.schema.json",
  "title": "Term",
  "description": "An art term or concept in the Korean Art Lexicon",
  "type": "object",
  "required": [
    "id",
    "term",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^term\\.[a-z0-9-]+$",
      "description": "Unique identifier in format: term.{slug}"
    },
    "term": {
      "type": "object",
      "required": [
        "ko"
      ],
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "string",
          "minLength": 1,
          "description": "Korean term"
        },
        "en": {
          "type": "object",
          "required": [
            "preferred"
          ],
          "additionalProperties": false,
          "properties": {
            "preferred": {
              "type": "string",
              "minLength": 1,
              "description": "Preferred English translation"
            },
            "type": {
              "type": "string",
              "enum": [
                "transliteration",
                "literal",
                "semantic",
                "loan"
              ],
              "description": "Translation type: transliteration (음역), literal (직역), semantic (의미역), loan (외래어)"
            }
          }
        },
        "hanja": {
          "type": "string",
          "description": "Hanja (Chinese characters)"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["form", "lang"],
            "additionalProperties": false,
            "properties": {
              "form": {
                "type": "string",
                "minLength": 1,
                "description": "The term variant string"
              },
              "lang": {
                "type": "string",
                "description": "ISO 639-1 language code"
              },
              "script": {
                "type": "string",
                "enum": ["Hang", "Hani", "Kore", "Latn", "Jpan", "Hans", "Hant"],
                "description": "ISO 15924 script code"
              },
              "type": {
                "type": "string",
                "enum": ["preferred", "alternate", "abbreviation", "former", "transliteration"],
                "description": "Variant type"
              },
              "romanization": {
                "type": "string",
                "enum": ["revised", "mcr", "yale", "artist", "conventional"],
                "description": "Romanization system (only when script=Latn)"
              },
              "source": {
                "type": "string",
                "description": "Institution or publication where this variant is used"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          },
          "description": "Term variants with language, script, and provenance"
        }
      }
    },
    "category": {
      "type": "object",
      "required": ["aat"],
      "additionalProperties": false,
      "properties": {
        "aat": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Getty AAT Subject ID for the term category"
        }
      },
      "description": "Term category as Getty AAT ID"
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "string",
          "description": "Korean definition"
        },
        "en": {
          "type": "string",
          "description": "English definition"
        }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "integer",
          "description": "Year the term/movement emerged"
        },
        "end": {
          "type": "integer",
          "description": "Year the term/movement ended (if applicable)"
        }
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(person|org|term|exhibition|publication)\\.[a-z0-9-]+$"
      },
      "description": "Related entities"
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aat": {
          "type": "string",
          "description": "Getty AAT Subject ID (if the term itself is in AAT)"
        },
        "wikidata": {
          "type": "string",
          "pattern": "^Q[0-9]+$",
          "description": "Wikidata Q-item ID"
        }
      },
      "description": "Links to external databases"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "url"
            ],
            "additionalProperties": false,
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              },
              "name_used": {
                "type": "string",
                "description": "Term form used in this source"
              },
              "note": {
                "type": "string"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          }
        ]
      },
      "description": "Verifiable sources"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "reviewed",
        "firsthand",
        "stable",
        "rejected"
      ],
      "default": "draft"
    },
    "notes": {
      "type": "string"
    }
  }
}
