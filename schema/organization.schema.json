{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korean-art-lexicon.org/schema/organization.schema.json",
  "title": "Organization",
  "description": "An organization entity: galleries, museums, artist-run spaces, art groups, institutions",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^org\\.[a-z0-9-]+$",
      "description": "Unique identifier in format: org.{slug}"
    },
    "name": {
      "type": "object",
      "required": [
        "ko"
      ],
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "string",
          "minLength": 1,
          "description": "Korean name"
        },
        "en": {
          "type": "string",
          "minLength": 1,
          "description": "English name"
        },
        "hanja": {
          "type": "string",
          "description": "Hanja (Chinese characters)"
        }
      }
    },
    "type": {
      "type": "string",
      "enum": [
        "museum",
        "gallery",
        "artist-run-space",
        "alternative-space",
        "art-group",
        "association",
        "foundation",
        "school",
        "biennale",
        "other"
      ],
      "description": "Organization type"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code"
        }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "integer",
          "description": "Year established"
        },
        "end": {
          "type": "integer",
          "description": "Year closed (if applicable)"
        },
        "active": {
          "type": "boolean",
          "description": "Currently active"
        }
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(person|org|term|exhibition)\\.[a-z0-9-]+$"
      },
      "description": "Related entities"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "url"
            ],
            "additionalProperties": false,
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              },
              "name_used": {
                "type": "string",
                "description": "Name form used in this source"
              },
              "note": {
                "type": "string"
              }
            }
          }
        ]
      },
      "description": "Verifiable sources"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "reviewed",
        "firsthand",
        "stable",
        "rejected"
      ],
      "default": "draft"
    },
    "notes": {
      "type": "string"
    }
  }
}