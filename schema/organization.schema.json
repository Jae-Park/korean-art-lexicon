{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://korean-art-lexicon.org/schema/organization.schema.json",
  "title": "Organization",
  "description": "An organization entity: galleries, museums, artist-run spaces, art groups, institutions",
  "type": "object",
  "required": [
    "id",
    "name",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^org\\.[a-z0-9-]+$",
      "description": "Unique identifier in format: org.{slug}"
    },
    "name": {
      "type": "object",
      "required": [
        "ko"
      ],
      "additionalProperties": false,
      "properties": {
        "ko": {
          "type": "string",
          "minLength": 1,
          "description": "Korean name"
        },
        "en": {
          "type": "string",
          "minLength": 1,
          "description": "English name"
        },
        "hanja": {
          "type": "string",
          "description": "Hanja (Chinese characters)"
        },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["form", "lang"],
            "additionalProperties": false,
            "properties": {
              "form": {
                "type": "string",
                "minLength": 1,
                "description": "The name variant string"
              },
              "lang": {
                "type": "string",
                "description": "ISO 639-1 language code"
              },
              "script": {
                "type": "string",
                "enum": ["Hang", "Hani", "Kore", "Latn", "Jpan", "Hans", "Hant"],
                "description": "ISO 15924 script code"
              },
              "type": {
                "type": "string",
                "enum": ["preferred", "alternate", "abbreviation", "former", "transliteration"],
                "description": "Variant type"
              },
              "source": {
                "type": "string",
                "description": "Institution or publication where this variant is used"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          },
          "description": "Name variants with language, script, and provenance"
        }
      }
    },
    "type": {
      "type": "object",
      "required": ["aat"],
      "additionalProperties": false,
      "properties": {
        "aat": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Getty AAT Subject ID for the organization type"
        }
      },
      "description": "Organization type as Getty AAT ID"
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code"
        }
      }
    },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "integer",
          "description": "Year established"
        },
        "end": {
          "type": "integer",
          "description": "Year closed (if applicable)"
        },
        "active": {
          "type": "boolean",
          "description": "Currently active"
        }
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(person|org|term|exhibition|publication)\\.[a-z0-9-]+$"
      },
      "description": "Related entities"
    },
    "external_ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ulan": {
          "type": "string",
          "description": "Getty ULAN Subject ID (for corporate bodies)"
        },
        "wikidata": {
          "type": "string",
          "pattern": "^Q[0-9]+$",
          "description": "Wikidata Q-item ID"
        },
        "viaf": {
          "type": "string",
          "description": "VIAF cluster ID"
        },
        "aaa": {
          "type": "string",
          "description": "Asia Art Archive actor ID"
        }
      },
      "description": "Links to external databases"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "url"
            ],
            "additionalProperties": false,
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              },
              "name_used": {
                "type": "string",
                "description": "Name form used in this source"
              },
              "note": {
                "type": "string"
              },
              "accessed": {
                "type": "string",
                "format": "date",
                "description": "Date the source was last accessed (YYYY-MM-DD)"
              }
            }
          }
        ]
      },
      "description": "Verifiable sources"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "pending_review",
        "reviewed",
        "firsthand",
        "stable",
        "rejected"
      ],
      "default": "draft"
    },
    "notes": {
      "type": "string"
    }
  }
}
